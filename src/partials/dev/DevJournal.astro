---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

import type { IFrontmatter, MarkdownInstance } from '@/components/boilerplate';
import type { Locale } from '@/utils/i18n';

export interface Props {
  locale: Locale;
  posts: MarkdownInstance<IFrontmatter>[];
  limit?: number;
}

const { locale, posts, limit = 4 } = Astro.props;

const thumbModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/posts/*.{jpg,jpeg,png,webp}',
  { eager: true },
);
const thumbBySlug: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(thumbModules)) {
  const stem = path.split('/').pop()?.replace(/\.[^.]+$/, '') ?? '';
  thumbBySlug[stem] = mod.default;
}

const slugAliases: Record<string, string> = {
  'cbtjournal-app': 'cbtjournal',
  'ai-enablement-consultant': 'ai-enablement',
};

const getThumb = (url: string | undefined): ImageMetadata | undefined => {
  if (!url) return undefined;
  const slug = url.replace(/\/$/, '').split('/').pop() ?? '';
  return thumbBySlug[slugAliases[slug] ?? slug];
};

const labels = {
  en: {
    sectionNum: '§ 02.3 / JOURNAL',
    sectionA: 'Recent ',
    sectionEm: 'writing.',
    viewAll: 'All posts',
    dateLocale: 'en-US',
  },
  fi: {
    sectionNum: '§ 02.3 / JULKAISUT',
    sectionA: 'Viimeaikaista ',
    sectionEm: 'kirjoittelua.',
    viewAll: 'Kaikki artikkelit',
    dateLocale: 'fi-FI',
  },
} as const;

const t = labels[locale];

const formatDate = (d: string) =>
  new Date(d).toLocaleDateString(t.dateLocale, {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });

const selected = posts.slice(0, limit);
const total = posts.length.toString().padStart(2, '0');
---

<section id="journal" class="shell journal">
  <div class="section-head">
    <div class="section-head__num">{t.sectionNum}</div>
    <h2 class="section-head__title">
      {t.sectionA}<em>{t.sectionEm}</em>
    </h2>
  </div>

  <ul class="journal__list">
    {
      selected.map((post, i) => {
        const postUrl = post.url?.startsWith('/') ? post.url : `/${post.url ?? ''}`;
        const href = locale === 'fi' ? postUrl.replace('/fi/', '/') : postUrl;
        const idx = `${(i + 1).toString().padStart(2, '0')} / ${total}`;
        const thumb = getThumb(post.url);
        return (
          <li class="journal__item">
            <a class="journal__link" href={href}>
              <span class="journal__idx">{idx}</span>
              <div class="journal__thumb">
                {thumb ? (
                  <Image
                    src={thumb}
                    alt=""
                    width={200}
                    height={150}
                    loading="lazy"
                  />
                ) : (
                  <div class="journal__thumb-placeholder" aria-hidden="true">
                    ▸
                  </div>
                )}
              </div>
              <time class="journal__date" datetime={post.frontmatter.pubDate}>
                {formatDate(post.frontmatter.pubDate)}
              </time>
              <h3 class="journal__title">{post.frontmatter.title}</h3>
              <p class="journal__desc">{post.frontmatter.description}</p>
              <span class="journal__arrow">→</span>
            </a>
          </li>
        );
      })
    }
  </ul>

  <div class="journal__more">
    <a class="journal__more-link" href={locale === 'fi' ? '/fi/posts' : '/posts'}>
      {t.viewAll} <span class="arrow">→</span>
    </a>
  </div>
</section>

<style>
  .journal {
    padding-top: 40px;
  }
  .journal__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .journal__item {
    border-bottom: 1px solid var(--color-line-soft);
  }
  .journal__link {
    display: grid;
    grid-template-columns: 60px 120px 120px 1fr 40px;
    gap: 24px;
    padding: 24px 0;
    align-items: center;
    text-decoration: none;
    color: inherit;
    transition: padding 0.3s, background 0.3s;
  }
  .journal__thumb {
    grid-row: span 2;
    align-self: center;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border: 1px solid var(--color-line);
    background: var(--color-bg-1);
  }
  .journal__thumb :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .journal__thumb-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: var(--color-text-mute);
    font-family: var(--font-mono);
    font-size: 24px;
  }
  .journal__link:hover {
    padding-left: 18px;
    background: linear-gradient(
      90deg,
      oklch(from var(--color-accent) l c h / 0.04),
      transparent 60%
    );
  }
  .journal__link:hover .journal__title {
    color: var(--color-accent);
  }
  .journal__link:hover .journal__arrow {
    transform: translateX(6px);
    color: var(--color-accent);
  }
  .journal__idx {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--color-text-mute);
  }
  .journal__date {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--color-text-mute);
    text-transform: uppercase;
  }
  .journal__title {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: 22px;
    line-height: 1.2;
    color: var(--color-text);
    margin: 0 0 6px;
    grid-column: 4;
    transition: color 0.2s;
  }
  .journal__desc {
    grid-column: 4;
    font-size: 13px;
    line-height: 1.55;
    color: var(--color-text-dim);
    margin: 0;
  }
  .journal__arrow {
    font-family: var(--font-mono);
    color: var(--color-text-mute);
    text-align: right;
    transition: transform 0.2s, color 0.2s;
  }
  .journal__more {
    margin-top: 32px;
    text-align: right;
  }
  .journal__more-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    border: 1px solid var(--color-line);
    background: var(--color-bg-1);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s, background 0.2s, transform 0.2s;
  }
  .journal__more-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-soft);
    transform: translateX(4px);
  }
  .journal__more-link .arrow {
    color: var(--color-accent);
  }

  @media (max-width: 900px) {
    .journal__link {
      grid-template-columns: 96px 1fr;
      gap: 14px 18px;
    }
    .journal__idx {
      grid-column: 1 / -1;
    }
    .journal__thumb {
      grid-row: auto;
      max-width: 140px;
      aspect-ratio: 4 / 3;
    }
    .journal__date {
      grid-column: 2;
    }
    .journal__title,
    .journal__desc {
      grid-column: 1 / -1;
    }
    .journal__arrow {
      display: none;
    }
  }
  @media (max-width: 520px) {
    .journal__link {
      grid-template-columns: 1fr;
    }
    .journal__thumb {
      max-width: none;
      aspect-ratio: 16 / 9;
    }
    .journal__date {
      grid-column: 1;
    }
  }
</style>
