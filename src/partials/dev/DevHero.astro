---
import { Image } from 'astro:assets';

import avatarImg from '@/assets/images/avatar.jpg';
import type { Locale } from '@/utils/i18n';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const labels = {
  en: {
    kicker: '02 / IT & Development',
    headA: 'Ship ',
    headEm: 'fast.',
    headB: 'Scale quiet.',
    lede:
      'Full-stack web development from responsive sites to complex applications. Modern JavaScript frameworks, WordPress, and custom solutions.',
    ledeStrong: '15+ years',
    ledeTail: ' across technology and creative industries.',
    specs: [
      ['Stack', 'React · Vue · Node'],
      ['Platforms', 'WordPress · Laravel'],
      ['Backend', 'Database & API Design'],
      ['Location', 'Helsinki, Finland · Remote'],
      ['Status', '● Available Q2 2026'],
    ] as const,
    tag: 'DEV · 01',
    portraitName: 'DAVITT BARRY',
    portraitLoc: 'HEL · FI',
  },
  fi: {
    kicker: '02 / IT & KEHITYS',
    headA: 'Toimita ',
    headEm: 'nopeasti.',
    headB: 'Skaalaudu hiljaa.',
    lede:
      'Full-stack web-kehitystä responsiivisista sivustoista monimutkaisiin sovelluksiin. Moderneja JavaScript-frameworkeja, WordPressiä ja räätälöityjä ratkaisuja.',
    ledeStrong: 'Yli 15 vuotta',
    ledeTail: ' teknologian ja luovien alojen parissa.',
    specs: [
      ['Stack', 'React · Vue · Node'],
      ['Alustat', 'WordPress · Laravel'],
      ['Backend', 'Tietokanta & API-suunnittelu'],
      ['Sijainti', 'Helsinki · etänä'],
      ['Tila', '● Avoinna Q2 2026'],
    ] as const,
    tag: 'DEV · 01',
    portraitName: 'DAVITT BARRY',
    portraitLoc: 'HEL · FI',
  },
} as const;

const t = labels[locale];
---

<section class="shell page-hero">
  <div class="page-hero__col page-hero__col--intro">
    <div class="page-hero__kicker">{t.kicker}</div>
    <h1 class="page-hero__title">
      {t.headA}<em>{t.headEm}</em><br />{t.headB}
    </h1>
    <p class="page-hero__lede">
      {t.lede} <strong>{t.ledeStrong}</strong>{t.ledeTail}
    </p>
  </div>

  <div class="page-hero__portrait">
    <span class="page-hero__portrait-tag">{t.tag}</span>
    <Image src={avatarImg} alt="Davitt Barry" width={480} height={480} loading="lazy" />
    <div class="page-hero__portrait-stat">
      <span>{t.portraitName}</span>
      <span class="mute">{t.portraitLoc}</span>
    </div>
  </div>

  <dl class="spec-list">
    {
      t.specs.map(([k, v]) => (
        <div>
          <span>{k}</span>
          <span class={v.startsWith('●') ? 'accent' : ''}>{v}</span>
        </div>
      ))
    }
  </dl>
</section>

<style>
  .page-hero {
    padding: 60px 0 40px;
    display: grid;
    grid-template-columns: 1fr 320px 280px;
    gap: 48px;
    align-items: end;
    border-bottom: 1px solid var(--color-line);
  }
  .page-hero__kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 28px;
  }
  .page-hero__kicker::before {
    content: '● ';
    text-shadow: 0 0 8px var(--color-accent);
  }
  .page-hero__title {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(44px, 6vw, 84px);
    line-height: 0.9;
    letter-spacing: -0.03em;
    margin: 0 0 24px;
    color: var(--color-text);
  }
  .page-hero__title em {
    font-style: normal;
    color: var(--color-accent);
    text-shadow: 0 0 calc(var(--glow) * 28px)
      oklch(from var(--color-accent) l c h / calc(var(--glow) * 0.8));
  }
  .page-hero__lede {
    font-size: 17px;
    line-height: 1.55;
    max-width: 48ch;
    color: var(--color-text-dim);
    margin: 0;
  }
  .page-hero__lede strong {
    color: var(--color-text);
    font-weight: 500;
  }

  .page-hero__portrait {
    position: relative;
    aspect-ratio: 4 / 5;
    border: 1px solid var(--color-line);
    background: var(--color-bg-1);
    overflow: hidden;
  }
  .page-hero__portrait img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.3) contrast(1.02);
    mix-blend-mode: luminosity;
  }
  .page-hero__portrait::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 50%,
      oklch(from var(--color-bg) l c h / 0.75)
    );
  }
  .page-hero__portrait-tag {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    background: var(--color-bg);
    padding: 4px 8px;
    border: 1px solid var(--color-accent);
  }
  .page-hero__portrait-stat {
    position: absolute;
    bottom: 14px;
    left: 14px;
    right: 14px;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--color-text);
    display: flex;
    justify-content: space-between;
  }
  .page-hero__portrait-stat .mute {
    color: var(--color-text-mute);
  }

  .spec-list {
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    border-top: 1px solid var(--color-line);
  }
  .spec-list div {
    display: grid;
    grid-template-columns: 140px 1fr;
    padding: 14px 0;
    border-bottom: 1px solid var(--color-line-soft);
    gap: 20px;
    color: var(--color-text);
  }
  .spec-list div span:first-child {
    color: var(--color-text-mute);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .spec-list .accent {
    color: var(--color-accent);
  }

  @media (max-width: 1100px) {
    .page-hero {
      grid-template-columns: 1fr 280px;
    }
    .spec-list {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 760px) {
    .page-hero {
      grid-template-columns: 1fr;
    }
    .page-hero__portrait {
      max-width: 280px;
    }
  }
</style>
