---
import type { Locale } from '@/utils/i18n';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const labels = {
  en: {
    sectionNum: '§ 02.1 / SERVICES',
    sectionA: 'What I ',
    sectionEm: 'build.',
    services: [
      {
        num: '01',
        title: 'Custom web applications',
        body: 'React & Vue SPAs, Node/Laravel backends, custom APIs — from MVP to production-grade.',
        meta: '▸ FROM CONCEPT TO DEPLOY',
      },
      {
        num: '02',
        title: 'E-commerce & CMS',
        body: 'WooCommerce, custom WordPress themes, headless integrations. Secure payments, inventory, multilingual editing.',
        meta: '▸ PERFORMANCE FIRST',
      },
      {
        num: '03',
        title: 'Modernization & consulting',
        body: 'Updating legacy platforms, architecture planning, stack selection, and strategy for your project.',
        meta: '▸ STRUCTURED & DOCUMENTED',
      },
    ],
    stackAccent: ['React', 'Vue', 'Node.js'],
    stackRest: [
      'TypeScript',
      'Laravel',
      'WordPress',
      'PostgreSQL',
      'MySQL',
      'REST',
      'GraphQL',
      'Tailwind',
      'Docker',
      'Git',
    ],
  },
  fi: {
    sectionNum: '§ 02.1 / PALVELUT',
    sectionA: 'Mitä ',
    sectionEm: 'rakennan.',
    services: [
      {
        num: '01',
        title: 'Räätälöidyt web-sovellukset',
        body: 'React- ja Vue-SPA-sovellukset, Node/Laravel-backendit, omat API:t — MVP:stä tuotantoon.',
        meta: '▸ KONSEPTISTA JULKAISUUN',
      },
      {
        num: '02',
        title: 'Verkkokauppa & CMS',
        body: 'WooCommerce, räätälöidyt WordPress-teemat, headless-integraatiot. Turvalliset maksut, varastonhallinta, monikielisyys.',
        meta: '▸ SUORITUSKYKY EDELLÄ',
      },
      {
        num: '03',
        title: 'Modernisointi & konsultointi',
        body: 'Vanhojen alustojen uudistaminen, arkkitehtuurisuunnittelu, teknologiavalinnat ja strategia projektillesi.',
        meta: '▸ JÄSENNELTY & DOKUMENTOITU',
      },
    ],
    stackAccent: ['React', 'Vue', 'Node.js'],
    stackRest: [
      'TypeScript',
      'Laravel',
      'WordPress',
      'PostgreSQL',
      'MySQL',
      'REST',
      'GraphQL',
      'Tailwind',
      'Docker',
      'Git',
    ],
  },
} as const;

const t = labels[locale];
---

<section class="shell services">
  <div class="section-head">
    <div class="section-head__num">{t.sectionNum}</div>
    <h2 class="section-head__title">
      {t.sectionA}<em>{t.sectionEm}</em>
    </h2>
  </div>

  <div class="services__grid">
    {
      t.services.map((s) => (
        <article class="service">
          <div class="service__num">{s.num}</div>
          <h3 class="service__title">{s.title}</h3>
          <p class="service__desc">{s.body}</p>
          <div class="service__meta">{s.meta}</div>
        </article>
      ))
    }
  </div>

  <div class="stack-bar">
    {t.stackAccent.map((chip) => <span class="chip chip--accent">{chip}</span>)}
    {t.stackRest.map((chip) => <span class="chip">{chip}</span>)}
  </div>
</section>

<style>
  .services {
    padding: 80px 0 40px;
  }
  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--color-line);
    border-left: 1px solid var(--color-line);
  }
  .service {
    padding: 28px 28px 32px;
    border-right: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    min-height: 260px;
    display: flex;
    flex-direction: column;
  }
  .service__num {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--color-text-mute);
    margin-bottom: 14px;
  }
  .service__title {
    font-family: var(--font-sans);
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: 0 0 12px;
    color: var(--color-text);
  }
  .service__desc {
    font-size: 13px;
    line-height: 1.55;
    color: var(--color-text-dim);
    margin: 0 auto 0 0;
    max-width: 38ch;
  }
  .service__meta {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-accent);
    letter-spacing: 0.12em;
    margin-top: 20px;
  }

  .stack-bar {
    margin: 60px 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .chip {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    padding: 8px 14px;
    border: 1px solid var(--color-line);
    border-radius: 100px;
    color: var(--color-text);
  }
  .chip--accent {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: var(--color-accent-soft);
  }

  @media (max-width: 900px) {
    .services__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
