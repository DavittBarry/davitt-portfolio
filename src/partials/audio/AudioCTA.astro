---
import type { Locale } from '@/utils/i18n';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const labels = {
  en: {
    kicker: '● Booking sessions · 2026',
    headA: 'Ready to ',
    headEm: 'mix?',
    body:
      "Every project is unique — pricing depends on track length, complexity, stems, and turnaround. Send a demo or project brief and you'll get a personalised quote within 24–48 h.",
    primary: 'Book a session',
    primaryHref: '/contact',
    ghost: 'Send a demo',
    ghostHref: 'mailto:davittbarry333@gmail.com?subject=Audio%20Inquiry',
  },
  fi: {
    kicker: '● Sessiovaraukset auki · 2026',
    headA: 'Valmis ',
    headEm: 'miksaamaan?',
    body:
      'Jokainen projekti on omanlainen — hinta riippuu kappaleen pituudesta, monimutkaisuudesta, stemeistä ja toimitusajasta. Lähetä demo tai briiffi ja saat räätälöidyn tarjouksen 24–48 tunnissa.',
    primary: 'Varaa sessio',
    primaryHref: '/fi/yhteystiedot',
    ghost: 'Lähetä demo',
    ghostHref: 'mailto:davittbarry333@gmail.com?subject=%C3%84%C3%A4nikysely',
  },
} as const;

const t = labels[locale];
---

<section class="shell audio-cta">
  <div class="audio-cta__kicker">{t.kicker}</div>
  <h2 class="audio-cta__title">{t.headA}<em>{t.headEm}</em></h2>
  <p class="audio-cta__body">{t.body}</p>
  <div class="audio-cta__row">
    <a class="btn btn--primary" href={t.primaryHref}>
      {t.primary} <span class="arrow">→</span>
    </a>
    <a class="btn" href={t.ghostHref}>
      {t.ghost} <span class="arrow">→</span>
    </a>
  </div>
</section>

<style>
  .audio-cta {
    padding-top: 100px;
    padding-bottom: 40px;
  }
  .audio-cta__kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 28px;
  }
  .audio-cta__title {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1;
    max-width: 20ch;
    margin: 0 0 24px;
    color: var(--color-text);
  }
  .audio-cta__title em {
    font-style: normal;
    color: var(--color-accent);
    text-shadow: 0 0 calc(var(--glow) * 24px)
      oklch(from var(--color-accent) l c h / calc(var(--glow) * 0.7));
  }
  .audio-cta__body {
    font-size: 15px;
    line-height: 1.55;
    color: var(--color-text-dim);
    max-width: 58ch;
    margin: 0 0 32px;
  }
  .audio-cta__row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
</style>
