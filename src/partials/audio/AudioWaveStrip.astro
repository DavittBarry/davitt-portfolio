---
import type { Locale } from '@/utils/i18n';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const labels = {
  en: {
    left: '◉ REC · BEFORE → AFTER',
    right: 'SESSION · 44.1 kHz · 24-bit',
    before: 'BEFORE',
    after: 'AFTER',
  },
  fi: {
    left: '◉ REC · ENNEN → JÄLKEEN',
    right: 'SESSIO · 44.1 kHz · 24-bit',
    before: 'ENNEN',
    after: 'JÄLKEEN',
  },
} as const;

const t = labels[locale];
---

<section class="shell wave-strip">
  <div class="wave-strip__lbl">
    <span>{t.left}</span>
    <span>{t.right}</span>
  </div>
  <svg viewBox="0 0 1200 120" preserveAspectRatio="none" role="img" aria-label="Before and after waveform comparison">
    <g id="wsA"></g>
    <g id="wsB" transform="translate(600,0)"></g>
    <line x1="600" x2="600" y1="0" y2="120" stroke="var(--color-accent)" stroke-width="1" stroke-dasharray="3 4"></line>
    <text x="20" y="16" font-family="JetBrains Mono" font-size="10" fill="var(--color-text-mute)" letter-spacing="2">{t.before}</text>
    <text x="1180" y="16" font-family="JetBrains Mono" font-size="10" fill="var(--color-accent)" letter-spacing="2" text-anchor="end">{t.after}</text>
  </svg>
</section>

<script>
  function drawWave(hostId: string, ragged: boolean, color: string) {
    const host = document.getElementById(hostId);
    if (!host) return;
    const N = 120;
    let s = '';
    for (let i = 0; i < N; i++) {
      const env = Math.sin((i / N) * Math.PI);
      const noise = ragged
        ? 0.3 + Math.random() * 0.7
        : 0.5 + 0.4 * Math.abs(Math.sin(i * 0.4)) + 0.1 * Math.sin(i * 1.2);
      const h = env * noise * 52;
      const x = i * (600 / N);
      s += `<rect x="${x}" y="${60 - h}" width="3" height="${h * 2}" rx="1" fill="${color}" opacity="${(0.4 + env * 0.5).toFixed(2)}"/>`;
    }
    host.innerHTML = s;
  }

  function init() {
    drawWave('wsA', true, 'var(--color-text-mute)');
    drawWave('wsB', false, 'var(--color-accent)');
  }

  init();
  document.addEventListener('astro:after-swap', init);
</script>

<style>
  .wave-strip {
    margin: 0 auto;
    padding: 40px 0;
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
  }
  .wave-strip__lbl {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-mute);
    margin-bottom: 16px;
  }
  .wave-strip svg {
    width: 100%;
    height: 120px;
    display: block;
  }
</style>
