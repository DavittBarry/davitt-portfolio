---
import type { Locale } from '@/utils/i18n';

type SubItem = {
  href: string;
  label: string;
};
type NavItem = {
  href: string;
  label: string;
  num: string;
  submenu?: SubItem[];
};

export interface Props {
  locale: Locale;
  currentPath?: string;
}

const labels = {
  en: {
    menuAria: 'Toggle navigation menu',
    homeAria: 'Davitt Barry — Home',
    items: [
      { href: '/', label: 'Home', num: '01' },
      {
        href: '/dev',
        label: 'IT & Development',
        num: '02',
        submenu: [
          { href: '/dev#services', label: 'Services' },
          { href: '/dev#work', label: 'Selected work' },
          { href: '/dev#journal', label: 'Journal' },
          { href: '/posts', label: 'All posts' },
        ],
      },
      {
        href: '/music',
        label: 'Music',
        num: '03',
        submenu: [
          { href: '/music#original', label: 'Originals' },
          { href: '/music#covers', label: 'Covers' },
          { href: '/music#gigs', label: 'Gig calendar' },
        ],
      },
      {
        href: '/audio-services',
        label: 'Audio Engineering',
        num: '04',
        submenu: [
          { href: '/audio-services#audio-services', label: 'Services' },
          { href: '/audio-services#process', label: 'Process' },
          { href: '/audio-services#studio', label: 'Studio' },
        ],
      },
      { href: '/contact', label: 'Contact', num: '05' },
    ] as NavItem[],
  },
  fi: {
    menuAria: 'Avaa navigointivalikko',
    homeAria: 'Davitt Barry — Etusivu',
    items: [
      { href: '/fi/', label: 'Etusivu', num: '01' },
      {
        href: '/fi/dev',
        label: 'IT & Kehitys',
        num: '02',
        submenu: [
          { href: '/fi/dev#services', label: 'Palvelut' },
          { href: '/fi/dev#work', label: 'Valitut työt' },
          { href: '/fi/dev#journal', label: 'Julkaisut' },
          { href: '/fi/posts', label: 'Kaikki artikkelit' },
        ],
      },
      {
        href: '/fi/musiikki',
        label: 'Musiikki',
        num: '03',
        submenu: [
          { href: '/fi/musiikki#original', label: 'Omat' },
          { href: '/fi/musiikki#covers', label: 'Coverit' },
          { href: '/fi/musiikki#gigs', label: 'Keikkakalenteri' },
        ],
      },
      {
        href: '/fi/audiopalvelut',
        label: 'Äänitekniikka',
        num: '04',
        submenu: [
          { href: '/fi/audiopalvelut#audio-services', label: 'Palvelut' },
          { href: '/fi/audiopalvelut#process', label: 'Prosessi' },
          { href: '/fi/audiopalvelut#studio', label: 'Studio' },
        ],
      },
      { href: '/fi/yhteystiedot', label: 'Yhteystiedot', num: '05' },
    ] as NavItem[],
  },
} as const;

const normalize = (p: string) => (p.length > 1 ? p.replace(/\/$/, '') : p);

const isActive = (itemHref: string, currentPath?: string) => {
  if (!currentPath) return false;
  return normalize(itemHref) === normalize(currentPath);
};

const { locale, currentPath } = Astro.props as Props;
const t = labels[locale];
const homeHref = locale === 'fi' ? '/fi/' : '/';
---

<header class="topnav">
  <div class="shell topnav__inner">
    <a href={homeHref} class="logo" aria-label={t.homeAria}>
      <db-logo class="logo__mark" size="40"></db-logo>
      <span class="logo__wordmark">DAVITT&nbsp;BARRY</span>
    </a>

    <div class="topnav__links">
      {t.items.map((item) => (
        <div class:list={['nav-item', item.submenu && 'nav-item--has-submenu']}>
          <a
            href={item.href}
            data-num={item.num}
            class={isActive(item.href, currentPath) ? 'is-active' : ''}
          >
            {item.label}
            {item.submenu && <span class="nav-item__chev" aria-hidden="true">▾</span>}
          </a>
          {item.submenu && (
            <div class="nav-submenu" role="menu">
              {item.submenu.map((sub) => (
                <a class="nav-submenu__link" href={sub.href} role="menuitem">
                  {sub.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>

    <div class="topnav__right">
      <div class="vumeter" aria-hidden="true"></div>
      <div class="lang-toggle" role="group" aria-label="Language / Kieli">
        <span class="lang-toggle__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
            <circle cx="12" cy="12" r="9"></circle>
            <path d="M3 12h18"></path>
            <path d="M12 3a13 13 0 0 1 0 18"></path>
            <path d="M12 3a13 13 0 0 0 0 18"></path>
          </svg>
        </span>
        <a
          href="#"
          data-lang="en"
          aria-label="Switch to English"
          class={`lang-switch ${locale === 'en' ? 'is-active' : ''}`}
        >
          EN
        </a>
        <span class="lang-toggle__sep" aria-hidden="true">/</span>
        <a
          href="#"
          data-lang="fi"
          aria-label="Vaihda suomeksi"
          class={`lang-switch ${locale === 'fi' ? 'is-active' : ''}`}
        >
          FI
        </a>
      </div>

      <button
        class="topnav__burger p-2 text-[color:var(--color-text-dim)] hover:text-[color:var(--color-accent)]"
        id="mobile-menu-button"
        type="button"
        aria-label={t.menuAria}
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <svg
          class="h-6 w-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.6"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<div class="mobile-drawer" id="mobile-menu">
  <div class="mobile-drawer__inner">
    {t.items.map((item) => (
      <div class="mobile-drawer__group">
        <a
          href={item.href}
          data-num={item.num}
          class={isActive(item.href, currentPath) ? 'is-active' : ''}
        >
          {item.label}
        </a>
        {item.submenu && (
          <div class="mobile-drawer__sub">
            {item.submenu.map((sub) => (
              <a class="mobile-drawer__sub-link" href={sub.href}>{sub.label}</a>
            ))}
          </div>
        )}
      </div>
    ))}
  </div>
</div>

<script>
  (function () {
    const btn = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');
    if (btn && menu) {
      const setBodyLock = (locked: boolean) => {
        document.documentElement.classList.toggle('has-drawer-open', locked);
        document.body.classList.toggle('has-drawer-open', locked);
      };
      const closeMenu = () => {
        menu.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
        setBodyLock(false);
      };
      btn.addEventListener('click', () => {
        const open = menu.classList.toggle('is-open');
        btn.setAttribute('aria-expanded', String(open));
        setBodyLock(open);
      });
      menu.querySelectorAll<HTMLAnchorElement>('a[href]').forEach((a) => {
        a.addEventListener('click', () => closeMenu());
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && menu.classList.contains('is-open')) closeMenu();
      });
    }

    const vumeter = document.querySelector<HTMLElement>('.topnav .vumeter');
    if (vumeter && !vumeter.dataset.built) {
      vumeter.dataset.built = '1';
      const N = 5;
      for (let i = 0; i < N; i++) {
        const s = document.createElement('span');
        s.style.height = '6px';
        vumeter.appendChild(s);
      }
      const bars = vumeter.querySelectorAll<HTMLElement>('span');
      const t0 = performance.now();
      function tick(now: number) {
        const t = (now - t0) / 1000;
        bars.forEach((b, i) => {
          const v =
            0.4 +
            0.6 *
              Math.abs(
                Math.sin(t * 2.4 + i * 0.7) + 0.3 * Math.sin(t * 5.1 + i),
              );
          const hi = i >= 3;
          b.style.height = `${(4 + v * 16).toFixed(1)}px`;
          b.style.background =
            v > 0.8 && hi
              ? 'var(--color-accent)'
              : v > 0.55
                ? 'oklch(from var(--color-accent) l c h / 0.6)'
                : 'var(--color-line)';
          b.style.boxShadow =
            v > 0.8 && hi ? '0 0 6px var(--color-accent)' : 'none';
        });
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    const langMap: Record<string, string> = {
      '/': '/fi/',
      '/dev': '/fi/dev',
      '/audio-services': '/fi/audiopalvelut',
      '/music': '/fi/musiikki',
      '/contact': '/fi/yhteystiedot',
      '/privacy': '/tietosuoja',
      '/privacy/': '/tietosuoja',
      '/fi/': '/',
      '/fi/dev': '/dev',
      '/fi/audiopalvelut': '/audio-services',
      '/fi/musiikki': '/music',
      '/fi/yhteystiedot': '/contact',
      '/tietosuoja': '/privacy',
      '/tietosuoja/': '/privacy',
    };

    document.querySelectorAll<HTMLAnchorElement>('.lang-switch').forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const target = e.currentTarget as HTMLAnchorElement;
        const targetLang = target.dataset.lang;
        const currentPath = window.location.pathname;
        let newPath = currentPath;

        if (currentPath === '/posts' || currentPath === '/posts/') {
          newPath = targetLang === 'fi' ? '/fi/posts' : currentPath;
        } else if (currentPath.startsWith('/posts/')) {
          newPath = targetLang === 'fi' ? '/fi/posts' : currentPath;
        } else if (
          currentPath === '/fi/posts' ||
          currentPath === '/fi/posts/'
        ) {
          newPath = targetLang === 'en' ? '/posts' : currentPath;
        } else if (currentPath.startsWith('/fi/posts/')) {
          newPath = targetLang === 'en' ? '/posts' : currentPath;
        } else if (
          currentPath === '/tietosuoja' ||
          currentPath === '/tietosuoja/'
        ) {
          newPath = targetLang === 'en' ? '/privacy' : '/tietosuoja';
        } else if (
          currentPath === '/privacy' ||
          currentPath === '/privacy/'
        ) {
          newPath = targetLang === 'fi' ? '/tietosuoja' : '/privacy';
        } else if (targetLang === 'fi' && !currentPath.startsWith('/fi')) {
          newPath = langMap[currentPath] || '/fi' + currentPath;
        } else if (targetLang === 'en' && currentPath.startsWith('/fi')) {
          newPath = langMap[currentPath] || currentPath.replace('/fi', '');
        }

        window.location.href = newPath + window.location.hash;
      });
    });
  })();
</script>
