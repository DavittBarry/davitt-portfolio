---
import type { Locale } from '@/utils/i18n';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const SC_TRACK =
  'https://soundcloud.com/davittbarry/if-i-ever-lose-my-faith-in-you-by-sting-davitt-barry-band-cover-live';
const SC_WIDGET_URL = `https://w.soundcloud.com/player/?url=${encodeURIComponent(SC_TRACK)}&color=%235ec9ef&auto_play=false&hide_related=true&show_comments=false&show_user=false&show_reposts=false&show_teaser=false&visual=false`;

const labels = {
  en: {
    kicker: '● 03 / MUSIC',
    midOrig: 'ORIGINALS',
    midCovers: 'COVERS',
    midGigs: 'GIGS',
    right: 'EST. 2005',
    headA: 'Compositions, covers ',
    headEm: '& live shows.',
    lede:
      'Original compositions and productions across multiple genres. From initial concept to final master, bringing artistic vision to life through sound - and performing it live across Finland.',
    socialsLabel: 'Follow · live clips & updates',
    playLabel: 'Play',
    pauseLabel: 'Pause',
    preview: {
      original: {
        mode: 'link',
        label: 'Featured',
        title: 'Aliud Phantasma · Turquoise Wash Away',
        meta: 'Davitt Barry · 2025 · Music video',
        href: 'https://www.youtube.com/watch?v=zYJyVhUtR-4',
        cta: 'Watch',
      },
      covers: {
        mode: 'audio',
        label: 'Now playing',
        title: 'If I Ever Lose My Faith In You · Sting (cover)',
        meta: 'Davitt Barry Band · live · audio',
        href: '',
        cta: 'Play',
      },
      gigs: {
        mode: 'audio',
        label: 'Now playing',
        title: 'If I Ever Lose My Faith In You · Sting (cover)',
        meta: 'Davitt Barry Band · live · audio',
        href: '',
        cta: 'Play',
      },
    },
  },
  fi: {
    kicker: '● 03 / MUSIIKKI',
    midOrig: 'ALKUPERÄISET',
    midCovers: 'COVERIT',
    midGigs: 'KEIKAT',
    right: 'PERUSTETTU 2005',
    headA: 'Sävellyksiä, covereita ',
    headEm: '& live-keikkoja.',
    lede:
      'Alkuperäisiä sävellyksiä ja tuotantoja eri genreissä. Konseptista masterointiin, taiteellisen vision toteuttaminen äänen kautta - ja livenä ympäri Suomen.',
    socialsLabel: 'Seuraa · live-klippejä & päivityksiä',
    playLabel: 'Toista',
    pauseLabel: 'Tauko',
    preview: {
      original: {
        mode: 'link',
        label: 'Kohokohta',
        title: 'Aliud Phantasma · Turquoise Wash Away',
        meta: 'Davitt Barry · 2025 · Musiikkivideo',
        href: 'https://www.youtube.com/watch?v=zYJyVhUtR-4',
        cta: 'Katso',
      },
      covers: {
        mode: 'audio',
        label: 'Soi nyt',
        title: 'If I Ever Lose My Faith In You · Sting (cover)',
        meta: 'Davitt Barry Band · live · audio',
        href: '',
        cta: 'Toista',
      },
      gigs: {
        mode: 'audio',
        label: 'Soi nyt',
        title: 'If I Ever Lose My Faith In You · Sting (cover)',
        meta: 'Davitt Barry Band · live · audio',
        href: '',
        cta: 'Toista',
      },
    },
  },
} as const;

const t = labels[locale];
const p = t.preview.original;
---

<section class="shell page-hero music-hero">
  <div class="page-hero__top">
    <span class="accent">{t.kicker}</span>
    <nav class="page-hero__nav" aria-label="Music section shortcuts">
      <a href="#original" data-mid="original">{t.midOrig}</a>
      <span aria-hidden="true">·</span>
      <a href="#covers" data-mid="covers">{t.midCovers}</a>
      <span aria-hidden="true">·</span>
      <a href="#gigs" data-mid="gigs">{t.midGigs}</a>
    </nav>
    <span>{t.right}</span>
  </div>

  <h1 class="page-hero__title">
    {t.headA}<em>{t.headEm}</em>
  </h1>
  <p class="page-hero__lede">{t.lede}</p>

  <div
    class="now-playing"
    id="np-panel"
    data-preview={JSON.stringify(t.preview)}
    data-play-label={t.playLabel}
    data-pause-label={t.pauseLabel}
  >
    <div>
      <div class="now-playing__lbl" id="np-lbl">{p.label}</div>
      <div class="now-playing__title" id="np-title">{p.title}</div>
      <div class="now-playing__meta" id="np-meta">{p.meta}</div>
    </div>
    <div class="np-wave" id="np-wave"></div>
    <button type="button" class="btn np-btn" id="np-cta" data-mode={p.mode}>
      <span class="np-icon" id="np-icon" aria-hidden="true">↗</span>
      <span id="np-cta-label">{p.cta}</span>
    </button>
  </div>

  <iframe
    id="sc-widget"
    title="SoundCloud player"
    src={SC_WIDGET_URL}
    allow="autoplay"
    aria-hidden="true"
    tabindex="-1"
  ></iframe>

  <div class="music-socials" aria-label="Davitt Barry on social platforms">
    <span class="music-socials__lbl">{t.socialsLabel}</span>
    <div class="music-socials__row">
      <a href="https://www.facebook.com/share/1Go8PEsNGN/" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.5 22v-8h2.7l.4-3.1h-3.1V8.9c0-.9.3-1.5 1.5-1.5h1.6V4.6c-.3 0-1.2-.1-2.3-.1-2.3 0-3.9 1.4-3.9 4v2.4H7.7V14h2.7v8h3.1z"/></svg>
        <span>Facebook</span>
      </a>
      <a href="https://www.instagram.com/davittbarry" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
        <span>Instagram</span>
      </a>
      <a href="https://www.tiktok.com/@davitt.barry" aria-label="TikTok" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.6 7.5a5.8 5.8 0 0 1-3.4-1.1 5.8 5.8 0 0 1-2.2-3.2h-3v12.5a2.6 2.6 0 1 1-1.9-2.5v-3a5.6 5.6 0 1 0 4.9 5.6V9.5a8.7 8.7 0 0 0 5.6 1.9v-3a5.6 5.6 0 0 1-.1-.9z"/></svg>
        <span>TikTok</span>
      </a>
    </div>
  </div>
</section>

<script is:inline src="https://w.soundcloud.com/player/api.js"></script>
<script>
  const wave = document.getElementById('np-wave');
  if (wave && !wave.childElementCount) {
    const frag = document.createDocumentFragment();
    const N = 72;
    for (let i = 0; i < N; i++) {
      const s = document.createElement('span');
      const env = Math.sin((i / N) * Math.PI);
      const noise = 0.4 + 0.5 * Math.abs(Math.sin(i * 0.45)) + 0.1 * Math.sin(i * 1.3);
      const h = Math.max(18, env * noise * 100);
      s.style.animationDelay = `${((i * 0.05) % 1.2).toFixed(2)}s`;
      s.style.height = `${h.toFixed(1)}%`;
      frag.appendChild(s);
    }
    wave.appendChild(frag);
  }
</script>

<style>
  .music-hero {
    padding-top: 60px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--color-line);
  }
  .page-hero__top {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 24px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-mute);
  }
  .page-hero__top .accent {
    color: var(--color-accent);
  }
  .page-hero__nav {
    display: inline-flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }
  .page-hero__nav a {
    color: var(--color-text-dim);
    text-decoration: none;
    border-bottom: 1px dashed transparent;
    padding: 2px 0;
    transition: color 0.2s, border-color 0.2s;
  }
  .page-hero__nav a:hover,
  .page-hero__nav a:focus-visible {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
    outline: none;
  }
  .page-hero__nav a.is-current {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  .page-hero__title {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(44px, 6vw, 84px);
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin: 0 0 24px;
    color: var(--color-text);
  }
  .page-hero__title em {
    font-style: normal;
    color: var(--color-accent);
    text-shadow: 0 0 calc(var(--glow) * 28px)
      oklch(from var(--color-accent) l c h / calc(var(--glow) * 0.8));
  }
  .page-hero__lede {
    font-size: 16px;
    line-height: 1.55;
    max-width: 58ch;
    color: var(--color-text-dim);
    margin: 0;
  }

  .now-playing {
    margin-top: 28px;
    border: 1px solid var(--color-line);
    padding: 18px 20px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 20px;
    align-items: center;
    background: var(--color-bg-1);
  }
  .now-playing.is-hidden {
    display: none;
  }
  .now-playing__lbl {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 4px;
  }
  .now-playing__lbl::before {
    content: '● ';
  }
  .now-playing__title {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text);
  }
  .now-playing__meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-mute);
    letter-spacing: 0.06em;
    margin-top: 3px;
  }
  .np-wave {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2px;
    height: 32px;
    width: 100%;
    min-width: 0;
  }
  .np-wave :global(span) {
    display: block;
    flex: 1 1 0;
    min-width: 2px;
    max-width: 5px;
    background: var(--color-accent);
    border-radius: 1px;
    box-shadow: 0 0 4px var(--color-accent);
    opacity: 0.9;
    animation: np-bounce 1.2s ease-in-out infinite;
  }
  @keyframes np-bounce {
    0%,
    100% {
      transform: scaleY(0.2);
    }
    50% {
      transform: scaleY(1);
    }
  }
  .np-btn {
    padding: 10px 16px;
    font-size: 11px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .np-icon {
    font-size: 12px;
    line-height: 1;
  }

  #sc-widget {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
    border: 0;
    left: -9999px;
    top: -9999px;
  }

  .music-socials {
    margin-top: 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .music-socials__lbl {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-mute);
  }
  .music-socials__row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .music-socials__row a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm, 4px);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    text-decoration: none;
    background: var(--color-bg-1);
    transition: all 0.2s;
  }
  .music-socials__row a:hover,
  .music-socials__row a:focus-visible {
    color: var(--color-accent);
    border-color: var(--color-accent);
    outline: none;
  }
  .music-socials__row svg {
    width: 16px;
    height: 16px;
  }

  @media (max-width: 1100px) {
    .music-hero {
      text-align: center;
    }
    .page-hero__top {
      justify-content: center;
    }
    .page-hero__lede {
      margin-left: auto;
      margin-right: auto;
    }
    .music-socials {
      align-items: center;
    }
    .music-socials__row {
      justify-content: center;
    }
  }
  @media (max-width: 700px) {
    .now-playing {
      grid-template-columns: 1fr;
      text-align: left;
    }
    .np-wave {
      justify-content: flex-start;
    }
  }
</style>
