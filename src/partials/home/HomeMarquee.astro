---
import type { Locale } from '@/utils/i18n';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const terms = {
  en: ['Code', 'Composition', 'Mastering', 'Production', 'Full-stack', 'Mixing'],
  fi: ['Koodi', 'Sävellys', 'Masterointi', 'Tuotanto', 'Full-stack', 'Miksaus'],
} as const;

const t = terms[locale];
---

<section class="marquee" aria-hidden="true">
  <div class="marquee__track">
    <span class="marquee__group">
      {
        t.map((term, i) => (
          <>
            <em>{term}</em>
            {i < t.length - 1 && <span class="marquee__dot" />}
          </>
        ))
      }
      <span class="marquee__dot"></span>
    </span>
    <span class="marquee__group">
      {
        t.map((term, i) => (
          <>
            <em>{term}</em>
            {i < t.length - 1 && <span class="marquee__dot" />}
          </>
        ))
      }
      <span class="marquee__dot"></span>
    </span>
  </div>
</section>

<style>
  .marquee {
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    overflow: hidden;
    padding: 28px 0;
    display: flex;
    gap: 60px;
    white-space: nowrap;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(22px, 3.6vw, 40px);
    color: var(--color-text);
    mask-image: linear-gradient(
      90deg,
      transparent,
      #000 10%,
      #000 90%,
      transparent
    );
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent,
      #000 10%,
      #000 90%,
      transparent
    );
  }
  .marquee__track {
    display: inline-flex;
    gap: 60px;
    align-items: center;
    animation: db-slide 40s linear infinite;
  }
  .marquee__group {
    display: inline-flex;
    align-items: center;
    gap: 60px;
  }
  .marquee__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 12px var(--color-accent);
    flex-shrink: 0;
    display: inline-block;
  }
  @keyframes db-slide {
    to {
      transform: translateX(-50%);
    }
  }
</style>
