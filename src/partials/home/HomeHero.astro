---
import type { Locale } from '@/utils/i18n';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const labels = {
  en: {
    loc: 'Helsinki · 60.1699° N',
    system: 'System : ONLINE · CH 01/24 · −3.0 dBFS',
    markCaption1: 'signal · ',
    markCaption2: ' · the monogram',
    markCaption3: 'initials in decibels · accent-tuned',
    liveLabel: 'Live signal · portfolio 2026',
    nameA: 'Davitt',
    nameB: 'Barry',
    roles: ['IT Professional', 'Musician', 'Audio Engineer'],
    bioIntro: 'Multi-disciplinary creative professional',
    bio: ' based in Uusimaa, Finland. Combining technical expertise in IT and web development with artistic vision in music production and audio engineering. Bringing ',
    bioYears: '15+ years',
    bioTail: ' of experience across technology and creative industries.',
    ctaPrimary: 'Start a project',
    ctaPrimaryHref: '/contact',
    ctaSecondary: 'Explore practice',
    portraitSubj: 'SUBJ · DAVITT BARRY',
    portraitLens: 'F/1.8 · 85MM',
  },
  fi: {
    loc: 'Helsinki · 60.1699° N',
    system: 'Järjestelmä : ONLINE · CH 01/24 · −3.0 dBFS',
    markCaption1: 'signaali · ',
    markCaption2: ' · monogrammi',
    markCaption3: 'nimikirjaimet desibeleinä · aksenttivireinen',
    liveLabel: 'Livesignaali · portfolio 2026',
    nameA: 'Davitt',
    nameB: 'Barry',
    roles: ['IT-ammattilainen', 'Muusikko', 'Ääniteknikko'],
    bioIntro: 'Monitaitoinen luova ammattilainen',
    bio: ' Uudeltamaalta. Yhdistän teknisen IT- ja web-kehitysosaamisen taiteelliseen näkemykseen musiikin tuotannossa ja äänitekniikassa. ',
    bioYears: 'Yli 15 vuoden',
    bioTail: ' kokemus teknologian ja luovien alojen parissa.',
    ctaPrimary: 'Aloita projekti',
    ctaPrimaryHref: '/fi/yhteystiedot',
    ctaSecondary: 'Tutki työkenttää',
    portraitSubj: 'SUBJ · DAVITT BARRY',
    portraitLens: 'F/1.8 · 85MM',
  },
} as const;

const t = labels[locale];
---

<section class="hero shell">
  <div class="hero__meta mono">
    <span class="loc">
      <span class="loc-dot" aria-hidden="true"></span>
      {t.loc}
    </span>
    <span class="hero__meta-sys">{t.system}</span>
    <span class="time" id="clock">—</span>
  </div>

  <div class="hero__mark">
    <div class="mark-caption">
      ▸ {t.markCaption1}<em>dB</em>{t.markCaption2}<br />
      ▸ {t.markCaption3}
    </div>
    <db-logo hero></db-logo>
  </div>

  <div class="hero__grid">
    <div>
      <div class="label label--accent hero__label">{t.liveLabel}</div>

      <h1 class="hero__name">
        {t.nameA}<br />
        <em>{t.nameB}</em>
      </h1>

      <div class="hero__roles">
        {t.roles.map((r) => <span class="role-tag">{r}</span>)}
      </div>

      <p class="hero__bio">
        <strong>{t.bioIntro}</strong>{t.bio}<strong>{t.bioYears}</strong>{t.bioTail}
      </p>

      <div class="hero__cta">
        <a class="btn btn--primary" href={t.ctaPrimaryHref}>
          {t.ctaPrimary} <span class="arrow">→</span>
        </a>
        <a class="btn" href="#pillars">
          {t.ctaSecondary} <span class="arrow">↓</span>
        </a>
      </div>

      <div class="socials" aria-label="Social links">
        <a href="https://github.com/DavittBarry" aria-label="GitHub" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.8-1.3-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.3 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.7.2 2.9.1 3.2.8.9 1.2 1.9 1.2 3.2 0 4.6-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3"/></svg>
        </a>
        <a href="https://www.linkedin.com/in/davittbarry/" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 2h-17A1.5 1.5 0 0 0 2 3.5v17A1.5 1.5 0 0 0 3.5 22h17a1.5 1.5 0 0 0 1.5-1.5v-17A1.5 1.5 0 0 0 20.5 2zM8 19H5V9h3v10zM6.5 7.7A1.7 1.7 0 1 1 6.5 4a1.7 1.7 0 0 1 0 3.7zM19 19h-3v-5.2c0-1.3-.5-2-1.6-2s-1.9.7-1.9 2V19h-3V9h2.9v1.3A3.4 3.4 0 0 1 15.2 9c2.1 0 3.8 1.3 3.8 4V19z"/></svg>
        </a>
        <a href="mailto:davittbarry333@gmail.com" aria-label="Email">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="1"/><path d="m3 7 9 6 9-6"/></svg>
        </a>
      </div>
    </div>

    <div class="hero__aside">
      <div class="portrait">
        <img src="/assets/images/avatar.jpg" alt="Davitt Barry" loading="eager" />
        <div class="portrait__grid"></div>
        <div class="portrait__crosshair"></div>
        <div class="portrait__stats">
          <span>{t.portraitSubj}</span>
          <span class="mute">{t.portraitLens}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function tickClock() {
    const d = new Date();
    const fmt = d.toLocaleTimeString('en-GB', {
      hour12: false,
      timeZone: 'Europe/Helsinki',
    });
    const el = document.getElementById('clock');
    if (el) el.textContent = fmt + ' EET';
  }
  tickClock();
  setInterval(tickClock, 1000);
</script>

<style>
  .hero {
    position: relative;
    padding: 80px 0 40px;
  }
  .hero__meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--color-line-soft);
    gap: 20px;
    flex-wrap: wrap;
  }
  .hero__meta .loc {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--color-text-dim);
  }
  .loc-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 8px var(--color-accent);
  }
  .hero__meta .time {
    font-variant-numeric: tabular-nums;
    color: var(--color-text);
  }
  .hero__meta-sys {
    color: var(--color-text-mute);
  }

  .hero__mark {
    position: relative;
    margin: 40px 0 32px;
    padding: 32px 0 28px;
    border-top: 1px solid var(--color-line-soft);
    border-bottom: 1px solid var(--color-line-soft);
  }
  .hero__mark db-logo {
    display: block;
  }
  .mark-caption {
    position: absolute;
    top: 12px;
    right: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-mute);
    text-align: right;
    line-height: 1.6;
  }
  .mark-caption em {
    color: var(--color-accent);
    font-style: normal;
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: end;
  }
  .hero__label {
    display: block;
    margin-bottom: 24px;
  }
  .hero__name {
    font-family: var(--font-serif);
    font-size: clamp(48px, 7.5vw, 104px);
    line-height: 0.9;
    letter-spacing: -0.03em;
    margin: 0 0 18px;
    color: var(--color-text);
    font-weight: 400;
  }
  .hero__name em {
    font-style: italic;
    color: var(--color-accent);
    text-shadow: 0 0 calc(var(--glow) * 30px)
      oklch(from var(--color-accent) l c h / calc(var(--glow) * 0.8));
  }

  .hero__roles {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 20px 0 28px;
  }
  .role-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text);
    padding: 8px 14px;
    border: 1px solid var(--color-line);
    border-radius: 100px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .role-tag::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 6px var(--color-accent);
  }

  .hero__bio {
    max-width: 44ch;
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-text-dim);
    margin: 0;
  }
  .hero__bio strong {
    color: var(--color-text);
    font-weight: 500;
  }

  .hero__cta {
    display: flex;
    gap: 12px;
    margin-top: 28px;
    flex-wrap: wrap;
  }

  .socials {
    display: flex;
    gap: 6px;
    margin-top: 24px;
  }
  .socials a {
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    color: var(--color-text-dim);
    transition: all 0.2s;
  }
  .socials a:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
  .socials svg {
    width: 18px;
    height: 18px;
  }

  .hero__aside {
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px;
  }
  .portrait {
    position: relative;
    aspect-ratio: 4 / 5;
    background: var(--color-bg-1);
    border: 1px solid var(--color-line);
    overflow: hidden;
  }
  .portrait img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.4) contrast(1.02);
    mix-blend-mode: luminosity;
  }
  .portrait::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 60%,
      oklch(from var(--color-bg) l c h / 0.85) 100%
    );
    pointer-events: none;
  }
  .portrait__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(
        oklch(from var(--color-accent) l c h / 0.08) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        oklch(from var(--color-accent) l c h / 0.08) 1px,
        transparent 1px
      );
    background-size: 40px 40px;
    pointer-events: none;
  }
  .portrait__crosshair {
    position: absolute;
    top: 16px;
    left: 16px;
    right: 16px;
    bottom: 16px;
    border: 1px solid oklch(from var(--color-accent) l c h / 0.5);
    pointer-events: none;
  }
  .portrait__crosshair::before,
  .portrait__crosshair::after {
    content: '';
    position: absolute;
    background: var(--color-accent);
  }
  .portrait__crosshair::before {
    top: -1px;
    left: -1px;
    width: 20px;
    height: 1px;
    box-shadow: 0 20px 0 0 var(--color-accent);
  }
  .portrait__crosshair::after {
    top: -1px;
    left: -1px;
    width: 1px;
    height: 20px;
    box-shadow: 20px 0 0 0 var(--color-accent);
  }
  .portrait__stats {
    position: absolute;
    bottom: 20px;
    left: 20px;
    right: 20px;
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text);
    z-index: 2;
  }
  .portrait__stats .mute {
    color: var(--color-text-mute);
  }

  @media (max-width: 900px) {
    .hero__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .mark-caption {
      position: static;
      margin-bottom: 12px;
      text-align: left;
    }
  }
</style>
