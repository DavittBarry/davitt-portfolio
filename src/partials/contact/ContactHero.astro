---
import type { Locale } from '@/utils/i18n';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const labels = {
  en: {
    kicker: '05 / Contact',
    headA: "Let's ",
    headEm: 'talk.',
    lede:
      "Whether you need a skilled developer, professional audio engineering, or original music compositions, I'm here to help bring your vision to life.",
    tag: 'SAY HELLO',
    nameTag: 'DAVITT BARRY',
    locTag: 'HEL · FI',
    stats: [
      ['Inbox', '● OPEN', true],
      ['Typical reply', '< 48 HRS', false],
      ['Languages', 'EN · FI', false],
      ['Time zone', 'EET · UTC+2', false],
    ] as const,
  },
  fi: {
    kicker: '05 / Yhteystiedot',
    headA: 'Puhutaan ',
    headEm: 'kahden.',
    lede:
      'Oli kyse kehittäjästä seuraavaan projektiisi, äänitekniikasta tai alkuperäisistä sävellyksistä — autan toteuttamaan vision.',
    tag: 'TERVE',
    nameTag: 'DAVITT BARRY',
    locTag: 'HEL · FI',
    stats: [
      ['Inbox', '● AUKI', true],
      ['Tyypillinen vastaus', '< 48 H', false],
      ['Kielet', 'FI · EN', false],
      ['Aikavyöhyke', 'EET · UTC+2', false],
    ] as const,
  },
} as const;

const t = labels[locale];
---

<section class="shell contact-hero">
  <div class="contact-hero__intro">
    <div class="contact-hero__kicker">{t.kicker}</div>
    <h1 class="contact-hero__title">
      {t.headA}<em>{t.headEm}</em>
    </h1>
    <p class="contact-hero__lede">{t.lede}</p>
  </div>

  <div class="contact-portrait">
    <span class="contact-portrait__tag">{t.tag}</span>
    <img
      src="/assets/images/avatar-2.jpg"
      alt="Davitt Barry"
      loading="lazy"
      onerror="this.style.display='none'"
    />
    <div class="contact-portrait__stat">
      <span>{t.nameTag}</span>
      <span>{t.locTag}</span>
    </div>
  </div>

  <div class="contact-stats">
    {t.stats.map(([k, v, accent]) => (
      <div class="contact-stat">
        <span>{k}</span>
        <span class={accent ? 'accent' : ''}>{v}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .contact-hero {
    padding: 60px 0 48px;
    display: grid;
    grid-template-columns: 1.2fr 260px 280px;
    gap: 40px;
    align-items: end;
    border-bottom: 1px solid var(--color-line);
  }
  .contact-hero__kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 28px;
  }
  .contact-hero__kicker::before {
    content: '● ';
  }
  .contact-hero__title {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(44px, 6vw, 84px);
    line-height: 0.88;
    letter-spacing: -0.03em;
    margin: 0 0 24px;
    color: var(--color-text);
  }
  .contact-hero__title em {
    font-style: normal;
    color: var(--color-accent);
    text-shadow: 0 0 calc(var(--glow) * 28px)
      oklch(from var(--color-accent) l c h / calc(var(--glow) * 0.8));
  }
  .contact-hero__lede {
    font-size: 17px;
    line-height: 1.55;
    max-width: 44ch;
    color: var(--color-text-dim);
    margin: 0;
  }

  .contact-portrait {
    position: relative;
    aspect-ratio: 4 / 5;
    border: 1px solid var(--color-line);
    overflow: hidden;
    background: var(--color-bg-1);
  }
  .contact-portrait img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.3) contrast(1.02);
    mix-blend-mode: luminosity;
  }
  .contact-portrait::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 55%,
      oklch(from var(--color-bg) l c h / 0.8)
    );
  }
  .contact-portrait__tag {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    background: var(--color-bg);
    padding: 4px 8px;
    border: 1px solid var(--color-accent);
  }
  .contact-portrait__stat {
    position: absolute;
    bottom: 14px;
    left: 14px;
    right: 14px;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--color-text);
    display: flex;
    justify-content: space-between;
  }
  .contact-portrait__stat span:last-child {
    color: var(--color-text-mute);
  }

  .contact-stats {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--color-text-mute);
    text-transform: uppercase;
    line-height: 1.8;
  }
  .contact-stat {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    border-top: 1px solid var(--color-line-soft);
    padding: 14px 0;
  }
  .contact-stat:first-child {
    border-top-color: var(--color-line);
  }
  .contact-stat:last-child {
    border-bottom: 1px solid var(--color-line);
  }
  .contact-stat span:last-child {
    color: var(--color-text);
  }
  .contact-stat span.accent {
    color: var(--color-accent);
  }

  @media (max-width: 900px) {
    .contact-hero {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .contact-portrait {
      max-width: 320px;
    }
  }
</style>
