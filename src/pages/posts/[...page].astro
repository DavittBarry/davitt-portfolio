---
import type { MarkdownInstance, Page } from 'astro';

import type { IFrontmatter } from '@/components/boilerplate';
import PostsListing from '@/partials/posts/PostsListing.astro';
import Base from '@/templates/Base.astro';
import { AppConfig } from '@/utils/AppConfig';
import { sortByDate } from '@/utils/Posts';

type PaginateFn = (
  data: MarkdownInstance<IFrontmatter>[],
  opts: { pageSize: number },
) => { params: Record<string, string>; props: { page: Page } }[];

export async function getStaticPaths({ paginate }: { paginate: PaginateFn }) {
  const allPosts = Object.values(
    import.meta.glob<MarkdownInstance<IFrontmatter>>('./*.md', {
      eager: true,
    }),
  );
  const sortedPosts = sortByDate(allPosts);
  return paginate(sortedPosts, { pageSize: 6 });
}

interface Props {
  page: Page<MarkdownInstance<IFrontmatter>>;
}

const { page } = Astro.props as Props;

const pageLabel = page.currentPage === 1 ? 'Journal' : `Journal · ${page.currentPage}`;
const title = `${pageLabel} - ${AppConfig.site_name}`;
const description =
  'Long-form notes on code, sound, and the places they overlap. Tutorials, project post-mortems, and occasional rants.';
---

<Base head={{ title, description }}>
  <PostsListing locale="en" page={page} />
</Base>
