---
import type { MarkdownInstance, Page } from 'astro';

import type { IFrontmatter } from '@/components/boilerplate';
import Base from '@/templates/Base.astro';
import { AppConfig } from '@/utils/AppConfig';
import { sortByDate } from '@/utils/Posts';

type PaginateFn = (
  data: MarkdownInstance<IFrontmatter>[],
  opts: { pageSize: number },
) => { params: Record<string, string>; props: { page: Page } }[];

export async function getStaticPaths({ paginate }: { paginate: PaginateFn }) {
  const allPosts = Object.values(
    import.meta.glob<MarkdownInstance<IFrontmatter>>('./*.md', {
      eager: true,
    }),
  );
  const sortedPosts = sortByDate(allPosts);
  return paginate(sortedPosts, { pageSize: 6 });
}

interface Props {
  page: Page<MarkdownInstance<IFrontmatter>>;
}

const { page } = Astro.props as Props;

const pageLabel = page.currentPage === 1 ? 'Journal' : `Journal · ${page.currentPage}`;
const title = `${pageLabel} - ${AppConfig.site_name}`;
const description =
  'Long-form notes on code, sound, and the places they overlap. Tutorials, project post-mortems, and occasional rants.';

const total = page.total;
const rangeStart = page.start + 1;
const rangeEnd = page.end + 1;

const categoryOf = (post: MarkdownInstance<IFrontmatter>): string => {
  const t = post.frontmatter.title.toLowerCase();
  if (t.includes('relex') || t.includes('support')) return 'Career';
  if (t.includes('ai') || t.includes('enablement')) return 'AI';
  if (t.includes('cbt') || t.includes('journal')) return 'Project';
  if (t.includes('web') || t.includes('development')) return 'Development';
  return 'Writing';
};

const readTimeOf = (post: MarkdownInstance<IFrontmatter>): string => {
  const body = post.rawContent ? post.rawContent() : '';
  const words = body.trim().split(/\s+/).length;
  const mins = Math.max(1, Math.round(words / 220));
  return `${mins} MIN`;
};

const formatDate = (d: string) =>
  new Date(d).toISOString().slice(0, 10);
---

<Base head={{ title, description }}>
  <section class="shell posts-hero">
    <div class="posts-hero__kicker">▸ Journal</div>
    <h1 class="posts-hero__title">
      Notes from the <em>studio &amp; stack.</em>
    </h1>
    <p class="posts-hero__lede">{description}</p>
  </section>

  <section class="shell posts-section">
    <div class="posts-section__meta">
      <span>▸ {page.currentPage === 1 ? 'Recent posts' : `Page ${page.currentPage} / ${page.lastPage}`}</span>
      <span>
        {String(rangeStart).padStart(2, '0')}–{String(rangeEnd).padStart(2, '0')} / {String(total).padStart(2, '0')}
      </span>
    </div>

    <div class="posts-grid">
      {page.data.map((post) => {
        const url = post.url ?? '#';
        return (
          <article class="post-card">
            <a class="post-card__link" href={url} aria-label={post.frontmatter.title} />
            <div class="post-card__meta">
              <span class="cat">{categoryOf(post)}</span>
              <span>{readTimeOf(post)}</span>
              <span>{formatDate(post.frontmatter.pubDate)}</span>
            </div>
            <h2 class="post-card__title">{post.frontmatter.title}</h2>
            <p class="post-card__excerpt">{post.frontmatter.description}</p>
            <div class="post-card__foot">
              <span>DAVITT BARRY</span>
              <span class="read">Read →</span>
            </div>
          </article>
        );
      })}
    </div>

    <nav class="posts-nav">
      {page.url.prev ? (
        <a class="btn" href={page.url.prev}>
          <span class="arrow">←</span> Newer posts
        </a>
      ) : <span />}
      <span class="posts-nav__pos">
        {page.currentPage} / {page.lastPage}
      </span>
      {page.url.next ? (
        <a class="btn" href={page.url.next}>
          Older posts <span class="arrow">→</span>
        </a>
      ) : <span />}
    </nav>
  </section>
</Base>

<style>
  .posts-hero {
    padding: 60px 0 40px;
    border-bottom: 1px solid var(--color-line);
  }
  .posts-hero__kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 24px;
  }
  .posts-hero__title {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(44px, 6vw, 84px);
    line-height: 0.95;
    margin: 0 0 20px;
    color: var(--color-text);
  }
  .posts-hero__title em {
    font-style: normal;
    color: var(--color-accent);
    text-shadow: 0 0 calc(var(--glow) * 28px)
      oklch(from var(--color-accent) l c h / calc(var(--glow) * 0.8));
  }
  .posts-hero__lede {
    font-size: 16px;
    line-height: 1.6;
    max-width: 58ch;
    color: var(--color-text-dim);
    margin: 0;
  }

  .posts-section {
    padding: 40px 0 80px;
  }
  .posts-section__meta {
    display: flex;
    justify-content: space-between;
    padding: 12px 0 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-mute);
    gap: 16px;
    flex-wrap: wrap;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-line);
    border: 1px solid var(--color-line);
  }
  .post-card {
    background: var(--color-bg);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    min-height: 260px;
    position: relative;
    transition: background 0.2s;
  }
  .post-card:hover {
    background: var(--color-bg-1);
  }
  .post-card:hover .post-card__title {
    color: var(--color-accent);
  }
  .post-card__link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .post-card__meta {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-mute);
    margin-bottom: 18px;
  }
  .post-card__meta .cat {
    color: var(--color-accent);
  }
  .post-card__title {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: 24px;
    line-height: 1.15;
    color: var(--color-text);
    margin: 0 0 14px;
    transition: color 0.2s;
  }
  .post-card__excerpt {
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-text-dim);
    margin: 0 0 auto;
    max-width: 48ch;
  }
  .post-card__foot {
    display: flex;
    justify-content: space-between;
    margin-top: 22px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--color-text-mute);
  }
  .post-card__foot .read {
    color: var(--color-accent);
  }

  .posts-nav {
    margin-top: 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .posts-nav__pos {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-mute);
  }

  @media (max-width: 820px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
