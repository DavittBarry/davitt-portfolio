---
import ContactAside from '@/partials/contact/ContactAside.astro';
import ContactForm from '@/partials/contact/ContactForm.astro';
import ContactHero from '@/partials/contact/ContactHero.astro';
import Base from '@/templates/Base.astro';

const title = 'Contact - Davitt Barry';
const description =
  'Get in touch for IT development, music production, or audio engineering services.';
---

<Base head={{ title, description }}>
  <ContactHero locale="en" />
  <section class="shell contact-grid">
    <ContactForm locale="en" />
    <ContactAside locale="en" />
  </section>
</Base>

<style>
  .contact-grid {
    padding: 60px 0 96px;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 56px;
    align-items: start;
  }
  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 40px 0 64px;
    }
  }
</style>
