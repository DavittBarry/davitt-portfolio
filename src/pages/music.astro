---
import type { ImageMetadata } from 'astro';
import { getImage } from 'astro:assets';

import { getLocalizedGigs } from '@/data/gigs';
import MusicCovers from '@/partials/music/MusicCovers.astro';
import MusicCTA from '@/partials/music/MusicCTA.astro';
import MusicGigs from '@/partials/music/MusicGigs.astro';
import MusicHero from '@/partials/music/MusicHero.astro';
import MusicOriginals from '@/partials/music/MusicOriginals.astro';
import Base from '@/templates/Base.astro';

const title = 'Music - Davitt Barry';
const description =
  'Original music and live cover gigs by Davitt Barry. Acoustic troubadour available for events across Finland.';

const gigs = getLocalizedGigs('en');
const yearsPlaying = new Date().getFullYear() - 2005;

const promoModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/images/promo/*.jpg',
  { eager: true },
);
const promos = await Promise.all(
  Object.entries(promoModules)
    .sort(([a], [b]) => a.localeCompare(b))
    .map(async ([_, mod], i) => {
      const fullSize = await getImage({
        src: mod.default,
        width: 2000,
        format: 'jpg',
        quality: 85,
      });
      return { image: mod.default, fullHref: fullSize.src, n: i + 1 };
    }),
);
---

<Base head={{ title, description }}>
  <MusicHero locale="en" />

  <section class="shell">
    <div class="tabs" role="tablist" aria-label="Music sections">
      <button
        type="button"
        class="tab on"
        role="tab"
        aria-selected="true"
        aria-controls="panel-original"
        data-tab="original"
        id="tab-original"
      >
        <span class="n">01</span> Originals
      </button>
      <button
        type="button"
        class="tab"
        role="tab"
        aria-selected="false"
        aria-controls="panel-covers"
        data-tab="covers"
        id="tab-covers"
      >
        <span class="n">02</span> Covers
      </button>
      <button
        type="button"
        class="tab"
        role="tab"
        aria-selected="false"
        aria-controls="panel-gigs"
        data-tab="gigs"
        id="tab-gigs"
      >
        <span class="n">03</span> Gig Calendar
      </button>
    </div>

    <section class="tab-panel on" data-panel="original" id="panel-original" role="tabpanel" aria-labelledby="tab-original">
      <MusicOriginals locale="en" />
    </section>
    <section class="tab-panel" data-panel="covers" id="panel-covers" role="tabpanel" aria-labelledby="tab-covers" hidden>
      <MusicCovers locale="en" promos={promos} yearsPlaying={yearsPlaying} />
    </section>
    <section class="tab-panel" data-panel="gigs" id="panel-gigs" role="tabpanel" aria-labelledby="tab-gigs" hidden>
      <MusicGigs locale="en" gigs={gigs} />
    </section>
  </section>

  <MusicCTA locale="en" />
</Base>

<script>
  function initMusicTabs() {
    const tabs = Array.from(
      document.querySelectorAll<HTMLButtonElement>('.tabs .tab'),
    );
    const panels = Array.from(
      document.querySelectorAll<HTMLElement>('.tab-panel'),
    );
    if (!tabs.length || !panels.length) return;

    const VALID = new Set(['original', 'covers', 'gigs']);

    const npPanel = document.getElementById('np-panel');
    const npLbl = document.getElementById('np-lbl');
    const npTitle = document.getElementById('np-title');
    const npMeta = document.getElementById('np-meta');
    const npCta = document.getElementById('np-cta') as HTMLButtonElement | null;
    const npCtaLabel = document.getElementById('np-cta-label');
    const npIcon = document.getElementById('np-icon');
    const scFrame = document.getElementById('sc-widget') as HTMLIFrameElement | null;
    const playLabel = npPanel?.getAttribute('data-play-label') || 'Play';
    const pauseLabel = npPanel?.getAttribute('data-pause-label') || 'Pause';
    let scWidget: any = null;
    let isPlaying = false;
    let currentMode: 'link' | 'audio' = 'link';
    let currentHref = '';

    const SC = (window as any).SC;
    if (scFrame && SC?.Widget) {
      scWidget = SC.Widget(scFrame);
      scWidget.bind(SC.Widget.Events.PLAY, () => {
        isPlaying = true;
        reflectPlayState();
      });
      scWidget.bind(SC.Widget.Events.PAUSE, () => {
        isPlaying = false;
        reflectPlayState();
      });
      scWidget.bind(SC.Widget.Events.FINISH, () => {
        isPlaying = false;
        reflectPlayState();
      });
    }

    function reflectPlayState() {
      if (!npPanel) return;
      npPanel.classList.toggle('is-playing', isPlaying && currentMode === 'audio');
      if (currentMode !== 'audio') return;
      if (npIcon) npIcon.textContent = isPlaying ? '⏸' : '▶';
      if (npCtaLabel) npCtaLabel.textContent = isPlaying ? pauseLabel : playLabel;
    }

    let previewData: Record<string, {
      mode: 'link' | 'audio';
      label: string;
      title: string;
      meta: string;
      href: string;
      cta: string;
    }> = {};
    if (npPanel) {
      try {
        previewData = JSON.parse(npPanel.getAttribute('data-preview') || '{}');
      } catch {
        previewData = {};
      }
    }

    function updatePreview(name: string) {
      if (!npPanel) return;
      const data = previewData[name];
      if (!data) {
        npPanel.classList.add('is-hidden');
        if (scWidget && isPlaying) scWidget.pause();
        return;
      }
      npPanel.classList.remove('is-hidden');
      currentMode = data.mode;
      currentHref = data.href;
      if (npLbl) npLbl.textContent = data.label;
      if (npTitle) npTitle.textContent = data.title;
      if (npMeta) npMeta.textContent = data.meta;
      if (npCta) npCta.setAttribute('data-mode', data.mode);
      if (data.mode === 'link') {
        if (scWidget && isPlaying) scWidget.pause();
        if (npIcon) npIcon.textContent = '↗';
        if (npCtaLabel) npCtaLabel.textContent = data.cta;
        npPanel.classList.remove('is-playing');
      } else {
        reflectPlayState();
      }
    }

    if (npCta) {
      npCta.addEventListener('click', () => {
        if (currentMode === 'link') {
          if (currentHref) window.open(currentHref, '_blank', 'noopener');
          return;
        }
        if (!scWidget) return;
        if (isPlaying) scWidget.pause();
        else scWidget.play();
      });
    }

    const midLinks = Array.from(
      document.querySelectorAll<HTMLAnchorElement>('.page-hero__nav a[data-mid]'),
    );
    function updateMid(name: string) {
      midLinks.forEach((a) => {
        a.classList.toggle('is-current', a.getAttribute('data-mid') === name);
      });
    }

    function switchTab(name: string | null, opts: { focus?: boolean } = {}) {
      if (!name || !VALID.has(name)) return;
      tabs.forEach((tab) => {
        const isActive = tab.getAttribute('data-tab') === name;
        tab.classList.toggle('on', isActive);
        tab.setAttribute('aria-selected', String(isActive));
        tab.setAttribute('tabindex', isActive ? '0' : '-1');
        if (isActive && opts.focus) tab.focus();
      });
      panels.forEach((panel) => {
        const isActive = panel.getAttribute('data-panel') === name;
        panel.classList.toggle('on', isActive);
        if (isActive) panel.removeAttribute('hidden');
        else panel.setAttribute('hidden', '');
      });
      updatePreview(name);
      updateMid(name);
    }

    tabs.forEach((tab, idx) => {
      tab.addEventListener('click', () => {
        const name = tab.getAttribute('data-tab');
        switchTab(name);
        if (name) history.replaceState(null, '', `#${name}`);
      });
      tab.addEventListener('keydown', (e) => {
        let next: number | null = null;
        if (e.key === 'ArrowRight') next = (idx + 1) % tabs.length;
        else if (e.key === 'ArrowLeft')
          next = (idx - 1 + tabs.length) % tabs.length;
        else if (e.key === 'Home') next = 0;
        else if (e.key === 'End') next = tabs.length - 1;
        if (next === null) return;
        e.preventDefault();
        const name = tabs[next]?.getAttribute('data-tab') ?? null;
        switchTab(name, { focus: true });
        if (name) history.replaceState(null, '', `#${name}`);
      });
    });

    const hash = window.location.hash.replace('#', '');
    if (VALID.has(hash)) switchTab(hash);
    else {
      tabs.forEach((tab) =>
        tab.setAttribute(
          'tabindex',
          tab.getAttribute('aria-selected') === 'true' ? '0' : '-1',
        ),
      );
      updatePreview('original');
      updateMid('original');
    }

    const onHash = () => {
      const h = window.location.hash.replace('#', '');
      if (VALID.has(h)) {
        switchTab(h);
        const panel = document.getElementById(`panel-${h}`);
        panel?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    };
    window.addEventListener('hashchange', onHash);
  }

  function initPromoToggle() {
    const btn = document.getElementById('toggle-promos');
    const wrap = document.getElementById('toggle-promos-wrap');
    if (!btn || !wrap) return;
    btn.addEventListener(
      'click',
      () => {
        document
          .querySelectorAll('.extra-promo')
          .forEach((el) => el.classList.remove('hidden'));
        wrap.remove();
      },
      { once: true },
    );
  }

  document.addEventListener(
    'error',
    (e) => {
      const target = e.target as HTMLElement | null;
      if (
        target instanceof HTMLImageElement &&
        target.hasAttribute('data-hide-parent-on-error')
      ) {
        const parent = target.closest('a');
        if (parent) parent.style.display = 'none';
      }
    },
    true,
  );

  initMusicTabs();
  initPromoToggle();
  document.addEventListener('astro:after-swap', () => {
    initMusicTabs();
    initPromoToggle();
  });
</script>

<style>
  .tabs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
    border-bottom: 1px solid var(--color-line);
    margin-top: 40px;
  }
  .tabs .tab {
    background: var(--color-bg-2);
    border: 1px solid var(--color-text-mute);
    border-bottom: 2px solid transparent;
    font: inherit;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text);
    padding: 14px 12px;
    cursor: pointer;
    margin-bottom: -1px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    text-align: center;
    transition:
      color 0.2s,
      background 0.2s,
      border-color 0.2s;
  }
  .tabs .tab::after {
    content: '▸';
    color: var(--color-accent);
    font-size: 10px;
    opacity: 0.8;
  }
  .tabs .tab .n {
    color: var(--color-accent);
    font-size: 10px;
  }
  .tabs .tab:hover {
    color: var(--color-accent);
    background: var(--color-accent-soft);
    border-color: var(--color-accent);
  }
  .tabs .tab.on {
    color: var(--color-accent);
    background: var(--color-accent-soft);
    border-color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  .tabs .tab.on::after {
    content: '●';
  }
  .tabs .tab.on .n {
    color: var(--color-accent);
  }
  .tabs .tab:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .tab-panel {
    display: none;
    padding: 40px 0;
  }
  .tab-panel.on {
    display: block;
  }

  @media (max-width: 520px) {
    .tabs .tab {
      font-size: 11px;
      padding: 12px 6px;
      letter-spacing: 0.04em;
    }
    .tabs .tab .n {
      display: none;
    }
  }
</style>
