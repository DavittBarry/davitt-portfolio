---
import ContactAside from '@/partials/contact/ContactAside.astro';
import ContactForm from '@/partials/contact/ContactForm.astro';
import ContactHero from '@/partials/contact/ContactHero.astro';
import Basefi from '@/templates/Basefi.astro';

const title = 'Yhteystiedot - Davitt Barry';
const description =
  'Ota yhteyttä IT-kehitys-, musiikkituotanto- tai äänitekniikkapalveluista.';
---

<Basefi head={{ title, description }}>
  <ContactHero locale="fi" />
  <section class="shell contact-grid">
    <ContactForm locale="fi" />
    <ContactAside locale="fi" />
  </section>
</Basefi>

<style>
  .contact-grid {
    padding: 60px 0 96px;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 56px;
    align-items: start;
  }
  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 40px 0 64px;
    }
  }
</style>
