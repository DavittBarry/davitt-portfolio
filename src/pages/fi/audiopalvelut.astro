---
import Basefi from '@/templates/Basefi.astro';

const title = 'Äänitekniikkapalvelut - Davitt Barry';
const description =
  'Ammattimaiset miksaus-, masterointi- ja äänituotantopalvelut. Raaka-äänityksistä kaupalliseen laatuun.';
---

<Basefi head={{ title, description }}>
  <div class="container mx-auto px-6 py-12">
    <!-- Hero Section -->
    <div class="mx-auto mb-16 max-w-4xl text-center">
      <h1 class="mb-4 text-5xl font-light text-white">
        Ääni<span class="text-cyan-400">tekniikka</span>
      </h1>
      <p class="text-xl text-neutral-400">
        Ammattimaiset miksaus- ja masterointipalvelut kaikille genreille
      </p>
    </div>

    <!-- Services Grid -->
    <div class="mx-auto mb-16 max-w-6xl">
      <h2 class="mb-8 text-3xl font-light text-white">Tarjotut palvelut</h2>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <div
          class="border border-neutral-800 bg-linear-to-br from-neutral-900 to-neutral-800 p-8 transition-all hover:border-cyan-400/50"
        >
          <div class="mb-4 text-3xl text-cyan-400">⚡</div>
          <h3 class="mb-3 text-xl text-white">Miksaus</h3>
          <p class="mb-4 text-neutral-400">
            Ammattimaiset miksauspalvelut tuomaan selkeyttä, syvyyttä ja
            tasapainoa kappaleisiisi.
          </p>
          <ul class="space-y-2 text-sm text-neutral-500">
            <li>• EQ:n ja kompression optimointi</li>
            <li>• Tilapaikkasijoittelu ja panorointi</li>
            <li>• Efektikäsittely</li>
            <li>• Stem-miksaus saatavilla</li>
          </ul>
        </div>

        <div
          class="border border-neutral-800 bg-linear-to-br from-neutral-900 to-neutral-800 p-8 transition-all hover:border-cyan-400/50"
        >
          <div class="mb-4 text-3xl text-cyan-400">🎯</div>
          <h3 class="mb-3 text-xl text-white">Masterointi</h3>
          <p class="mb-4 text-neutral-400">
            Viimeinen viilaus varmistaaksesi, että musiikkisi kuulostaa hyvältä
            kaikissa toistoympäristöissä.
          </p>
          <ul class="space-y-2 text-sm text-neutral-500">
            <li>• Äänenvoimakkuuden optimointi suoratoistopalveluille</li>
            <li>• Tonaalinen tasapaino ja parantaminen</li>
            <li>• Formaattivalmistelu (Spotify, Apple Music, jne.)</li>
            <li>• DDP-luonti fyysiselle medialle</li>
          </ul>
        </div>

        <div
          class="border border-neutral-800 bg-linear-to-br from-neutral-900 to-neutral-800 p-8 transition-all hover:border-cyan-400/50"
        >
          <div class="mb-4 text-3xl text-cyan-400">🎙️</div>
          <h3 class="mb-3 text-xl text-white">Podcast-tuotanto</h3>
          <p class="mb-4 text-neutral-400">
            Täydellinen podcast-jälkituotanto raaka-äänityksistä
            julkaisuvalmiisiin jaksoihin.
          </p>
          <ul class="space-y-2 text-sm text-neutral-500">
            <li>• Dialogin editointi ja puhdistus</li>
            <li>• Kohinanpoisto ja parannus</li>
            <li>• Musiikin ja äänisuunnittelun integrointi</li>
            <li>• Moniraita-editointi</li>
          </ul>
        </div>

        <div
          class="border border-neutral-800 bg-linear-to-br from-neutral-900 to-neutral-800 p-8 transition-all hover:border-cyan-400/50"
        >
          <div class="mb-4 text-3xl text-cyan-400">🔧</div>
          <h3 class="mb-3 text-xl text-white">Äänen restaurointi</h3>
          <p class="mb-4 text-neutral-400">
            Henkiin vanhat tai vaurioituneet äänitteet modernien
            restaurointitekniikoiden avulla.
          </p>
          <ul class="space-y-2 text-sm text-neutral-500">
            <li>• Kohinan ja sihinän poisto</li>
            <li>• Napsahduksien ja poksahduksien eliminointi</li>
            <li>• Taajuusrestauratio</li>
            <li>• Formaattimuunnos ja arkistointi</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Process Section -->
    <div class="mx-auto mb-16 max-w-4xl">
      <h2 class="mb-8 text-3xl font-light text-white">Prosessi</h2>
      <div class="space-y-6">
        <div class="flex gap-4">
          <div class="font-mono text-2xl text-cyan-400">01</div>
          <div>
            <h3 class="mb-2 text-xl text-white">Konsultointi</h3>
            <p class="text-neutral-400">
              Keskustellaan projektisi tavoitteista, referenssikappaleista ja
              aikataulusta.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="font-mono text-2xl text-cyan-400">02</div>
          <div>
            <h3 class="mb-2 text-xl text-white">Tiedostonsiirto</h3>
            <p class="text-neutral-400">
              Turvallinen äänitiedostojen lataus yksityiskohtaisilla
              sessiomuistiinpanoilla.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="font-mono text-2xl text-cyan-400">03</div>
          <div>
            <h3 class="mb-2 text-xl text-white">Tuotanto</h3>
            <p class="text-neutral-400">
              Ammattimainen käsittely käyttäen alan standardityökaluja ja
              -tekniikoita.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="font-mono text-2xl text-cyan-400">04</div>
          <div>
            <h3 class="mb-2 text-xl text-white">Tarkistus</h3>
            <p class="text-neutral-400">
              Jopa 2 tarkistuskierrosta varmistaaksemme täydellisen
              tyytyväisyytesi.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="font-mono text-2xl text-cyan-400">05</div>
          <div>
            <h3 class="mb-2 text-xl text-white">Toimitus</h3>
            <p class="text-neutral-400">
              Lopulliset tiedostot toimitetaan haluamassasi formaatissa ja
              resoluutiossa.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Studio Setup Section (moved from Music page) -->
    <div class="mx-auto mb-16 max-w-4xl">
      <h2 class="mb-8 text-3xl font-light text-white">Studio-setup</h2>
      <div
        class="border border-neutral-800 bg-linear-to-br from-neutral-900 to-neutral-800 p-8"
      >
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
          <div>
            <h3 class="mb-4 text-lg text-cyan-400">Ohjelmistot</h3>
            <ul class="space-y-2 text-neutral-400">
              <li>• Ableton Live</li>
            </ul>
          </div>
          <div>
            <h3 class="mb-4 text-lg text-cyan-400">Laitteisto</h3>
            <ul class="space-y-2 text-neutral-400">
              <li>
                • Äänikortti: Audient (mikrofonietuaste Ferrofish-muuntimella)
              </li>
              <li>
                • Monitorit: Genelec-tarkkailukaiuttimet (äänenvoimakkuus
                säädetään SPL-monitorikontrollerilla)
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Get a Quote Section -->
    <div class="mx-auto mb-16 max-w-4xl">
      <h2 class="mb-8 text-3xl font-light text-white">
        Pyydä räätälöity tarjous
      </h2>
      <div
        class="border border-neutral-800 bg-linear-to-br from-neutral-900 to-neutral-800 p-8"
      >
        <p class="mb-6 text-neutral-400">
          Jokainen projekti on ainutlaatuinen, ja hinnoittelu riippuu useista
          tekijöistä, kuten kappaleen pituudesta, monimutkaisuudesta, stemien
          määrästä ja toimitusajasta. Tarjoan kilpailukykyisiä hintoja ja
          pakettitarjouksia albumeille ja jatkuville projekteille.
        </p>
        <p class="mb-8 text-neutral-400">
          Ota yhteyttä projektisi tiedoilla saadaksesi henkilökohtaisen
          tarjouksen. Vastaan yleensä 24-48 tunnin sisällä yksityiskohtaisella
          arviolla ja aikataululla.
        </p>
        <div class="text-center">
          <a
            href="/fi/yhteystiedot"
            class="inline-block border border-cyan-400 px-6 py-3 text-cyan-400 transition-all hover:bg-cyan-400/10"
          >
            Pyydä tarjous →
          </a>
        </div>
      </div>
    </div>
  </div>
</Basefi>
