---
import AudioCTA from '@/partials/audio/AudioCTA.astro';
import AudioHero from '@/partials/audio/AudioHero.astro';
import AudioProcess from '@/partials/audio/AudioProcess.astro';
import AudioServices from '@/partials/audio/AudioServices.astro';
import AudioStudio from '@/partials/audio/AudioStudio.astro';
import AudioWaveStrip from '@/partials/audio/AudioWaveStrip.astro';
import Basefi from '@/templates/Basefi.astro';

const title = 'Äänitekniikka - Davitt Barry';
const description =
  'Ammattimaiset miksaus-, masterointi- ja äänituotantopalvelut. Raaka-äänityksistä kaupalliseen valmiuteen.';
---

<Basefi head={{ title, description }}>
  <AudioHero locale="fi" />
  <AudioWaveStrip locale="fi" />
  <AudioServices locale="fi" />
  <AudioProcess locale="fi" />
  <AudioStudio locale="fi" />
  <AudioCTA locale="fi" />
</Basefi>
