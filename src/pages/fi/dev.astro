---
import type { MarkdownInstance } from 'astro';

import type { IFrontmatter } from '@/components/boilerplate';
import DevCTA from '@/partials/dev/DevCTA.astro';
import DevHero from '@/partials/dev/DevHero.astro';
import DevJournal from '@/partials/dev/DevJournal.astro';
import DevServices from '@/partials/dev/DevServices.astro';
import DevWork from '@/partials/dev/DevWork.astro';
import Basefi from '@/templates/Basefi.astro';
import { AppConfig } from '@/utils/AppConfig';
import { sortByDate } from '@/utils/Posts';

const allPosts = Object.values(
  import.meta.glob<MarkdownInstance<IFrontmatter>>('../posts/*.md', {
    eager: true,
  }),
);
const sortedPosts = sortByDate(allPosts);

const title = 'IT & Kehitys - Davitt Barry';
const { description } = AppConfig;
---

<Basefi head={{ title, description }}>
  <DevHero locale="fi" />
  <DevServices locale="fi" />
  <DevWork locale="fi" />
  <DevJournal locale="fi" posts={sortedPosts} />
  <DevCTA locale="fi" />
</Basefi>
