---
import type { IFrontmatter } from '@/components/boilerplate';
import { CTOService } from '@/partials/CTOService';
import { CVDownload } from '@/partials/CVDownload';
import { Hero } from '@/partials/Hero';
import { ProjectList } from '@/partials/ProjectList';
import { RecentPosts } from '@/partials/RecentPosts';
import Basefi from '@/templates/Basefi.astro';
import { AppConfig } from '@/utils/AppConfig';
import { sortByDate } from '@/utils/Posts';

const allPosts = await Astro.glob<IFrontmatter>('../posts/*.md');
const sortedPosts = sortByDate(allPosts);

const title = 'IT & Kehitys - Davitt Barry';
const { description } = AppConfig;
---

<Basefi head={{ title, description }}>
  <Hero locale="fi" />
  <ProjectList locale="fi" />
  <RecentPosts client:load postList={sortedPosts} locale="fi" />
  <CTOService locale="fi" />
  <CVDownload locale="fi" />
</Basefi>
